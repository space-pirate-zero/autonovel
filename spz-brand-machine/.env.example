# SPZ Brand Machine — copy the values you need into the repo-root .env
# (the package reads ../.env then ./.env). Never commit real credentials.

# LLM
ANTHROPIC_API_KEY=

# Substack (private API, cookie auth — copy from a logged-in browser:
# DevTools → Application → Cookies → substack.com; `python -m
# spz_brand_machine.login` maintains sid/lli/cf_clearance automatically)
SPZ_SUBSTACK_SID=
SPZ_SUBSTACK_LLI=
SPZ_SUBSTACK_CONNECT_SID=
SPZ_SUBSTACK_CF_CLEARANCE=
SPZ_SUBSTACK_PUBLICATION_URL=https://spacepiratezero.substack.com
# Optional: browser UA sent with private-API requests
SPZ_SUBSTACK_USER_AGENT=

# Meta (official Graph API; IG must be Business/Creator linked to the Page)
SPZ_META_PAGE_ID=
SPZ_META_PAGE_ACCESS_TOKEN=
SPZ_META_IG_USER_ID=
SPZ_META_GRAPH_VERSION=v21.0

# Safety knobs
SPZ_KILL_SWITCH=false
SPZ_AUTOPILOT_DRY_RUN=true
SPZ_PRICE_MIN_MONTHLY=5
SPZ_PRICE_MAX_MONTHLY=15
SPZ_PRICE_MIN_ANNUAL=30
SPZ_PRICE_MAX_ANNUAL=150
SPZ_PRICE_MAX_DELTA_FRAC=0.34
SPZ_RATE_SUBSTACK_PER_HOUR=3
SPZ_RATE_META_PER_HOUR=6
SPZ_BRAND_MIN_SCORE=80

# Persistent browser session (optional)
SPZ_CHROME_PROFILE_DIR=

# Logs
SPZ_AUDIT_LOG=audit_log.jsonl
