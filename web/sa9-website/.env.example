# ══════════════════════════════════════
# SA9 Enterprise Environment Variables
# Copy to .env.local for local development
# ══════════════════════════════════════

# ── Website ──
BASE_DOMAIN=localhost
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Storefront Feature Flag ──
# Set to "true" to enable checkout and show real prices.
# Set to "false" (default) to show "Coming Soon" and waitlist only.
# Toggle via: make store-open / make store-close
NEXT_PUBLIC_STORE_OPEN=false

# ── PostgreSQL ──
POSTGRES_USER=sa9
POSTGRES_PASSWORD=sa9_dev_password_change_me
POSTGRES_DB=sa9_main
DATABASE_URL=postgresql://sa9:sa9_dev_password_change_me@postgres:5432/sa9_main

# ── Redis ──
REDIS_URL=redis://redis:6379

# ── PostHog Analytics ──
POSTHOG_API_KEY=phc_development_key
POSTHOG_HOST=http://analytics.localhost

# ── Clerk Auth ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_WAITLIST_URL=/waitlist

# ── Listmonk Email ──
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=admin_dev_change_me

# ── Twenty CRM ──
TWENTY_SERVER_URL=http://crm.localhost

# ── Sentry (optional) ──
# SENTRY_DSN=

# ── Stripe (optional) ──
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
