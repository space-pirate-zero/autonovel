# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Book title (used in drafting prompts)
AUTONOVEL_BOOK_TITLE=Digital Insurgency

# Writer model (used for drafting and revision)
AUTONOVEL_WRITER_MODEL=claude-opus-4-8

# Judge model (used for evaluation)
AUTONOVEL_JUDGE_MODEL=claude-opus-4-8

# Review model (Opus — deep prose-level analysis, used in Phase 3b)
AUTONOVEL_REVIEW_MODEL=claude-opus-4-8

# API base URL
AUTONOVEL_API_BASE_URL=https://api.anthropic.com

# fal.ai key for image generation (Nano Banana 2)
FAL_KEY=your-fal-api-key-here

# ElevenLabs API key for audiobook generation
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# --- X (Twitter) @spaceshipalpha9 channel (x/) ---
# OAuth 1.0a user-context keys (required to post/manage). Mint at
# developer.x.com with the app set to "Read and write". See x/README.md.
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret
# Optional: OAuth2 app-only bearer (read-only lookups)
X_BEARER_TOKEN=your-x-bearer-token
# Optional: default account handle (defaults to spaceshipalpha9)
X_HANDLE=spaceshipalpha9
