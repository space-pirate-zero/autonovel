        },
        {
          "id": "ch01-sc01-sh02",
          "description": "Close on Space Pirate Zero's face lit by screen-glow, warning of woe.",
          "characters": [
            "SPACE_PIRATE_ZERO"
          ],
          "camera": "CU, slow push-in",
          "est_seconds": 9,
          "dialogue": [
            {
              "character": "SPACE_PIRATE_ZERO",
              "text": "It is a tale of woe. I'll tell you that up front, the way an honest man tells you the dog dies, because you should know going in what you're spending your evening on."
            }
          ],
          "content_flags": [],
          "render": {
            "engine": "seedance2",
            "kind": "cloud",
            "filtered": true,
            "flags": [],
            "sensitive": false,
            "reason": "clean content \u2192 first preferred engine"
          }
        },
        {
          "id": "ch01-sc01-sh03",
          "description": "Ghostly overlay on the static: a man lifting an award to the light in a glittering ballroom.",
          "characters": [
            "SPACE_PIRATE_ZERO"
          ],
          "camera": "Match-dissolve overlay",
          "est_seconds": 10,
          "dialogue": [
            {
              "character": "SPACE_PIRATE_ZERO",
              "text": "It opens, as the good woeful ones do, at a party: a man handed an award for being the last of his kind, lifting it to the light, reading the engraving as a coronation when it is, in every line, a death certificate with generous margins."
            }
          ],
          "content_flags": [],
          "render": {
            "engine": "seedance2",
            "kind": "cloud",
            "filtered": true,
            "flags": [],
            "sensitive": false,
            "reason": "clean content \u2192 first preferred engine"
          }
        },
        {
          "id": "ch01-sc01-sh04",
          "description": "Space Pirate Zero gestures at the dark, the count of thirty-one machines hanging in the air.",
          "characters": [
            "SPACE_PIRATE_ZERO"
          ],
          "camera": "MEDIUM, firelight flicker",
          "est_seconds": 11,
          "dialogue": [
            {
              "character": "SPACE_PIRATE_ZERO",
              "text": "Thirty-one of the hundred have already handed the chair to the machine. Our man toasts the eleven who haven't, and mistakes a countdown for an ovation, and I am going to tell you the whole of how he got from that ballroom to the dark at the bottom, all of it, because someone should, and you are the only one still listening."
            }
          ],
          "content_flags": [],
          "render": {
            "engine": "seedance2",
            "kind": "cloud",
            "filtered": true,
            "flags": [],
            "sensitive": false,
            "reason": "clean content \u2192 first preferred engine"
          }
        },
        {
          "id": "ch01-sc01-sh05",
          "description": "Space Pirate Zero leans in conspiratorially; the transmission ID flickers across the screen.",
          "characters": [
            "SPACE_PIRATE_ZERO"
          ],
          "camera": "CU into static cut",
          "est_seconds": 6,
          "dialogue": [
