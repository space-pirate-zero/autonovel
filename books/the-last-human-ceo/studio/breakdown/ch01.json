      "heading": "EXT. SALVAGE DECKS - TRANSMISSION",
      "location": "SALVAGE_DECKS",
      "summary": "Space Pirate Zero tunes in the audience and frames the tale of woe.",
      "shots": [
        {
          "id": "ch01-sc01-sh01",
          "description": "Static-laced screen flickers; a ruined salvage deck glows behind a lone figure leaning toward an old set.",
          "characters": [
            "SPACE_PIRATE_ZERO"
          ],
          "camera": "WIDE establishing through static",
          "est_seconds": 8,
          "dialogue": [
            {
              "character": "SPACE_PIRATE_ZERO",
              "text": "Pull your chair in close to the set, friend, and never mind the static \u2014 out here on the salvage decks the static is most of what's left, and the rest is the story I've been waiting for somebody to tune in and hear."
            }
          ],
          "content_flags": [],
          "render": {
            "engine": "seedance2",
            "kind": "cloud",
            "filtered": true,
            "flags": [],
            "sensitive": false,
            "reason": "clean content \u2192 first preferred engine"
